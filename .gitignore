# Datasets / large binary assets — keep out of git (use cloud or git-lfs if needed)
test/

# Trained NCNN models — regenerated by retraining, kept local only
*.ncnn.bin
*.ncnn.param

# Audio assets (WAV) — re-recorded as needed, kept local only
*.wav

# Build artifacts
*.exe

# demo/ = local working folder for raw captures (video + screenshots) — kept out of git.
